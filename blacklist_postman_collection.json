{
  "info": {
    "name": "Blacklist Email Microservice",
    "description": "Colección para probar todos los endpoints del microservicio de blacklist de emails.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Agregar email a blacklist",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer fixedtoken" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"test@example.com\",\n  \"app_uuid\": \"123e4567-e89b-12d3-a456-426614174000\",\n  \"blocked_reason\": \"spam\"\n}"
        },
        "url": {
          "raw": "http://localhost:5000/blacklists/",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["blacklists", ""]
        },
        "description": "Agrega un email a la blacklist.\n\nCampos requeridos:\n- email (string, obligatorio)\n- app_uuid (UUID, obligatorio)\n- blocked_reason (string, opcional, máx 255)"
      },
      "response": []
    },
    {
      "name": "Consultar email en blacklist (existe)",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer fixedtoken" }
        ],
        "url": {
          "raw": "http://localhost:5000/blacklists/test@example.com",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["blacklists", "test@example.com"]
        },
        "description": "Consulta si un email está en la blacklist y muestra el motivo si existe."
      },
      "response": []
    },
    {
      "name": "Consultar email en blacklist (no existe)",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer fixedtoken" }
        ],
        "url": {
          "raw": "http://localhost:5000/blacklists/notfound@example.com",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["blacklists", "notfound@example.com"]
        },
        "description": "Consulta un email que no está en la blacklist. Debe responder exists: false o 404."
      },
      "response": []
    }
  ]
}
